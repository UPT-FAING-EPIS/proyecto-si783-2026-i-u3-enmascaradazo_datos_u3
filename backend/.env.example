# Configuración Enmask — copia a .env y ajusta (desarrollo local primero)
API_V1_STR=/api/v1
PROJECT_NAME=Enmask SDM Platform

# Orígenes explícitos del front (coma). Si lo dejas vacío por error, el backend usa un default seguro.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# Opcional: regex para Vite por IP de LAN (ej. http://192.168.0.4:5173). Pon false para desactivar.
# BACKEND_CORS_ORIGIN_REGEX=false

# Opcional: clave X-API-KEY (dejar vacío en local si no la usas)
API_KEY=

# JWT — cambia SECRET_KEY en cualquier entorno real
SECRET_KEY=cambia_esto_en_desarrollo
# Correos que tendrán rol administrador. Ejemplo: ADMIN_EMAILS=admin@demo.com,otro@demo.com
ADMIN_EMAILS=

# Metadatos: memory basta para probar en local (se borra al reiniciar el API)
REPOSITORY_BACKEND=memory
POSTGRES_META_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/enmask_meta
MONGODB_META_URI=mongodb://127.0.0.1:27017
METADATA_DATABASE=enmask_meta
GOOGLE_CLIENT_ID=

# Cuando despliegues: añade tus dominios a BACKEND_CORS_ORIGINS y usa postgres/mongodb según tu hosting.

# Llave simetrica Fernet para encriptacion de datos. Generar con:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENMASK_MASTER_KEY=

# Drivers/conectores opcionales por motor:
# - SQL Server: requiere Microsoft ODBC Driver 18 instalado en el sistema.
# - Oracle: usa python-oracledb en modo thin, normalmente sin cliente Oracle adicional.
# - Cassandra: requiere acceso al puerto CQL 9042 y keyspace existente.
# - Neo4j: se conecta por Bolt, puerto 7687.
# - Redis: usa puerto 6379 y el campo database como índice lógico DB, por ejemplo 0.
